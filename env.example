# Copy this to .env.local and fill in your values

# Contact form email delivery (Web3Forms)
# Sign up free at https://web3forms.com — no domain verification needed
# Just enter your email there and it gives you an access key instantly
#
# NOTE: this MUST be prefixed with NEXT_PUBLIC_ because the form submits
# directly from the browser to Web3Forms (not through a server route).
# Web3Forms access keys are designed to be public — they're safe to expose
# client-side, same as how Formspree/Netlify Forms keys work.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Site URL (used for OG images etc.)
NEXT_PUBLIC_SITE_URL=https://sudarshanrijal.dev
